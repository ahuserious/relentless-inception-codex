# OPT-IN EXAMPLE — merge this table into user-level ~/.codex/config.toml.
# Do not replace the whole file, and do not put this provider table in a
# project-scoped .codex/config.toml; Codex ignores machine-local provider/auth
# settings there.
#
# Set XAI_API_KEY in the environment that launches Codex. Never paste its value
# into this file.
#
# VERIFIED CODEX 0.145 BOUNDARY: custom Responses providers advertise/send
# namespace tools by default, while xAI rejects type="namespace" with HTTP 422.
# A hardened foreground session with every tool surface disabled passed one Grok
# 4.5 text smoke test, but a real spawned custom-agent turn still failed with
# HTTP 422 due an unsupported xAI `ModelInput` shape. Tool-result continuation
# also failed with a compaction-blob error. Do not register native Grok on the
# tested Codex 0.145 build. Use the plugin's direct external xAI seats for Grok
# subagents, fusion, provider-hosted tools, and review.

[model_providers.xai]
name = "xAI Responses"
base_url = "https://api.x.ai/v1"
env_key = "XAI_API_KEY"
env_key_instructions = "Set XAI_API_KEY in the environment that launches Codex."
wire_api = "responses"
request_max_retries = 2
stream_max_retries = 2
stream_idle_timeout_ms = 3600000
supports_websockets = false

# Selecting this provider globally would change the active Codex session:
# model_provider = "xai"
# model = "grok-4.5"
# model_reasoning_effort = "high"
#
# Retest this provider only from the hardened reasoning-only custom-agent layer
# after Codex or xAI changes. Do not leave that role registered on Codex 0.145.
