# OPT-IN EXAMPLE — merge this table into user-level ~/.codex/config.toml.
# Do not replace the whole file, and do not put this provider table in a
# project-scoped .codex/config.toml; Codex ignores machine-local provider/auth
# settings there.
#
# Set XAI_API_KEY in the environment that launches Codex. Never paste its value
# into this file.
#
# VERIFIED CODEX 0.145 BOUNDARY: custom Responses providers advertise/send
# namespace tools by default, while xAI rejects type="namespace" with HTTP 422.
# A hardened role with all tool-producing features and inherited MCP servers
# disabled passed a single-turn Grok 4.5 text smoke test. Tool-result continuation
# still failed with a compaction-blob decode error, so use this provider only for
# reasoning-only native review. Use the plugin's direct external xAI seats for
# fusion, provider-hosted tools, and any workflow that needs tool use.
# Tracking issue: https://github.com/openai/codex/issues/14242

[model_providers.xai]
name = "xAI Responses"
base_url = "https://api.x.ai/v1"
env_key = "XAI_API_KEY"
env_key_instructions = "Set XAI_API_KEY in the environment that launches Codex."
wire_api = "responses"
request_max_retries = 2
stream_max_retries = 2
stream_idle_timeout_ms = 3600000
supports_websockets = false

# Selecting this provider globally would change the active Codex session:
# model_provider = "xai"
# model = "grok-4.5"
# model_reasoning_effort = "high"
#
# Select this provider only from the hardened reasoning-only custom-agent layer.
# Do not select it globally or ask that role to call a tool on Codex 0.145.
